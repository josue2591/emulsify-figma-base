<section role="region" aria-labelledby="shadows-heading" class="sb-region">
  <div class="sb-header">
    <h2 id="shadows-heading" class="sb-header__title">Shadows</h2>
    <p class="sb-header__subtitle">Soft, slate-tinted shadows. Usage: <code>shadow(name)</code> → <code>var(--shadow-name)</code>.</p>
  </div>

  <div class="sb-content">
    <table class="sb-table">
      <thead>
        <tr>
          <th scope="col">Token</th>
          <th scope="col">CSS Variable</th>
          <th scope="col">Description</th>
          <th scope="col">Preview</th>
        </tr>
      </thead>
      <tbody>
      {% for shadow in shadows %}
        <tr role="button" class="js-copy-trigger" title="Click to copy" data-usage="{{ shadow.usage }}">
          <th>{{ shadow.label }}</th>
          <td><code>--shadow-{{ shadow.name }}</code></td>
          <td>{{ shadow.description }}</td>
          <td>
            <span style="display:inline-block; width:4rem; height:2.5rem; background:#ffffff; border-radius:0.75rem; box-shadow:{{ shadow.value }}; border:1px solid #e2e8f0;" aria-hidden="true"></span>
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</section>
